# ==============================================================================
# OrchardDB Master GitIgnore Rules
# Covers Python backend, React frontend, client SDK packaging, and local databases.
# ==============================================================================

# --- Python Virtual Environments & Packages ---
venv/
backend/venv/
ENV/
env/
.venv/
build/
dist/
*.egg-info/
client/dist/
client/build/
client/src/orchard_client.egg-info/
**/orchard_client.egg-info/

# --- Python Compiled Cache ---
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.coverage
htmlcov/

# --- Environment Secrets & Credentials ---
.env
backend/.env
frontend/.env
client/.env
*.pem
*.key

# --- Local Databases & Persistent Vector Indexes (Trial Data) ---
backend/data/
**/metadata.db
**/chroma.sqlite3
**/chroma/
scratch_*.py

# --- Node.js Dependencies & Frontend Caches ---
node_modules/
frontend/node_modules/
frontend/.svelte-kit/
frontend/.next/
.npm
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Operating System & Editor Settings ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini
plans
content.md